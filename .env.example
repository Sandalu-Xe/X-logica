# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── Email / Backend Configuration ──────────────────────────────────────────
# GMAIL_USER: The Gmail address that will SEND emails (must be info.xlogica@gmail.com)
GMAIL_USER="info.xlogica@gmail.com"

# GMAIL_APP_PASSWORD: A Gmail App Password (NOT your regular password).
# Steps to create one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already)
#   3. Search "App Passwords" → Create one for "Mail" / "Other (X-Logica)"
#   4. Paste the 16-character password below (spaces are OK)
GMAIL_APP_PASSWORD="vefy tfah fwte iuft"

# SERVER_PORT: Port for the Express API backend (default: 3001)
SERVER_PORT=3001
