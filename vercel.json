{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.ts": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/api/apply",   "destination": "/api/apply" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
